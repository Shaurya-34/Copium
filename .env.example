# ──────────────────────────────────────────────────────────
# CloudCFO — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# REQUIRED: Slack Incoming Webhook URL
# Get one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional overrides
SLACK_CHANNEL=#cloud-costs
SLACK_BOT_NAME=CloudCFO
SLACK_BOT_EMOJI=:cloud:
SLACK_TIMEOUT_SECONDS=10
SLACK_MAX_RETRIES=3

# Optional AWS + anomaly detection settings
AWS_REGION=us-east-1
ANOMALY_BASELINE_DAYS=7
ANOMALY_DATA_LAG_DAYS=1
ANOMALY_MINIMUM_DAILY_COST=10
ANOMALY_MINIMUM_COST_INCREASE=5
ANOMALY_SPIKE_MULTIPLIER=1.5
ANOMALY_SCORE_SCALE_DOLLARS=100
